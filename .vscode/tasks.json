{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build debug",
            "type": "process",
            "command": "C:/raylib/w64devkit/bin/g++.exe",
            "args": [
                "-std=c++14",
                "-g",
                "-I",
                "C:/raylib/raylib/src",
                "src/*.cpp",
                "-L",
                "C:/raylib/raylib/src",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-luser32",
                "-o",
                "main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "build release",
            "type": "process",
            "command": "C:/raylib/w64devkit/bin/g++.exe",
            "args": [
                "-std=c++14",
                "-O2",
                "-s",
                "-mwindows",
                "-I",
                "C:/raylib/raylib/src",
                "src/*.cpp",
                "-L",
                "C:/raylib/raylib/src",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-luser32",
                "-o",
                "RuntimeTerror.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "compiler: C:\\raylib\\w64devkit\\bin\\g++.exe"
        }
    ]
}
